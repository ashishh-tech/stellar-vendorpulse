# ═══════════════════════════════════════════════════════════════
# VendorPulse - Stellar/Soroban Environment Configuration
# ═══════════════════════════════════════════════════════════════

# ── Stellar Network ──────────────────────────────────────────
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
NEXT_PUBLIC_STELLAR_EXPLORER_URL=https://stellar.expert/explorer/testnet

# ── Smart Contract Addresses ─────────────────────────────────
# (Populated after deployment — see deployment docs)
NEXT_PUBLIC_VENDOR_REGISTRY_CONTRACT_ID=
NEXT_PUBLIC_REVIEW_SYSTEM_CONTRACT_ID=

# ── Deployer Identity ────────────────────────────────────────
STELLAR_DEPLOYER_ACCOUNT=vendorpulse-deployer

# ── App Configuration ────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=VendorPulse
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Observability ─────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_LOGGING=true
NEXT_PUBLIC_LOG_LEVEL=debug
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
